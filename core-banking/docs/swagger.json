        "/v1.0/transfer/status": {
            "post": {
                "description": "Fetch transaction status conforming to SNAP BI using Service Code 36.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "transactions"
                ],
                "summary": "Transfer Status Inquiry",
                "parameters": [
                    {
                        "type": "string",
