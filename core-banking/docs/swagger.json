                        "name": "X-SIGNATURE",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "default": "1234567890",
                        "description": "Random unique ID representing the request",
                        "name": "X-EXTERNAL-ID",
                        "in": "header",
                        "required": true
                    },
                    {
                        "description": "Transfer Payload",
                        "name": "request",
                        "in": "body",
                        "required": true,
