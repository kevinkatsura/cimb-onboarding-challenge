                ],
                "summary": "Transaction History List (SNAP v1.2)",
                "parameters": [
                    {
                        "type": "string",
                        "default": "PARTNER001",
                        "description": "Partner ID provided by the bank",
                        "name": "X-PARTNER-ID",
                        "in": "header",
                        "required": true
                    },
                    {
                        "type": "string",
                        "default": "2026-04-12T18:00:00Z",
